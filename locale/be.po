msgstr "?? незаконнае значэнне вяртання getopt %d\n"

#: src/dvdisaster.c:816 src/main-window.c:153
#, c-format
msgid ""
"\n"
"Method %s not available.\n"
"Use -m without parameters for a method list.\n"
