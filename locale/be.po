#: src/dvdisaster.c:862 src/main-window.c:216
msgid "RS01 method not available for comparing files."
msgstr "Метад RS01 недаступны для параўнання файлаў."

#. TRANSLATORS: Program options like -r and --read are not to be translated
#. to avoid confusion when discussing the program in international forums.
#: src/dvdisaster.c:960
msgid ""
"\n"
"Common usage examples:\n"
"  dvdisaster -r, --read   # Read the medium image to hard disk.\n"
"                          # Use -rn-m to read a certain sector range, e.g. -r100-200\n"
"  dvdisaster -c, --create # Create .ecc information for the medium image.\n"
"  dvdisaster -f, --fix    # Try to fix medium image using .ecc information.\n"
"  dvdisaster -s, --scan   # Scan the medium for read errors.\n"
"  dvdisaster -t, --test   # Test integrity of the .iso and .ecc files.\n"
"  dvdisaster -z, --strip  # Strip ECC data from an augmented .iso.\n"
"  dvdisaster -u, --unlink # Delete .iso files (when other actions complete)\n"
"\n"
msgstr ""
"\n"
"Прыклады выкарыстання:\n"
"  dvdisaster -r, --read   # Чытанне вобраза носьбіта на жорсткі дыск.\n"
"                          # Выкарыстоўвайце -rn-m для чытання дыяпазону сектараў, напр. -r100-200\n"
"  dvdisaster -c, --create # Стварэнне інфармацыі .ecc для вобраза носьбіта.\n"
"  dvdisaster -f, --fix    # Спроба выправіць вобраз носьбіта з дапамогай інфармацыі .ecc.\n"
"  dvdisaster -s, --scan   # Сканаванне носьбіта на памылкі чытання.\n"
"  dvdisaster -t, --test   # Праверка цэласнасці файлаў .iso і .ecc.\n"
"  dvdisaster -z, --strip  # Выдаленне даных ECC з дапоўненага .iso.\n"
"  dvdisaster -u, --unlink # Выдаленне файлаў .iso (пасля завяршэння іншых дзеянняў)\n"
"\n"

#: src/dvdisaster.c:970
#, c-format
msgid ""
"Drive and file specification:\n"
"  -d, --device device         - read from given device   (default: %s)\n"
"  -p, --prefix prefix         - prefix of .iso/.ecc file (default: medium.*  )\n"
"  -i, --image imagefile       - name of image file       (default: medium.iso)\n"
"  -e, --ecc eccfile           - name of parity file      (default: medium.ecc)\n"
"  -o, --ecc-target imagefile  - where to put ecc data in RS03\n"
msgstr ""
"Прылада і файлы:\n"
"  -d, --device прылада        - чытаць з пазначанай прылады  (па змаўчанні: %s)\n"
"  -p, --prefix прэфікс        - прэфікс файла .iso/.ecc       (па змаўчанні: medium.*  )\n"
"  -i, --image файл-вобраза    - імя файла вобраза             (па змаўчанні: medium.iso)\n"
"  -e, --ecc файл-ecc          - імя файла парытэту            (па змаўчанні: medium.ecc)\n"
"  -o, --ecc-target файл-вобраза - куды змяшчаць даныя ECC у RS03\n"

#: src/dvdisaster.c:980
msgid "Tweaking options (see manual before using!)\n"
msgstr "Дадатковыя параметры (прачытайце кіраўніцтва перад выкарыстаннем!)\n"

#: src/dvdisaster.c:981
msgid ""
"  -a, --assume x             - assume image is augmented with given codec "
"(RS02 or RS03)\n"
msgstr ""
"  -a, --assume x             - лічыць, што вобраз дапоўнены пазначаным "
"кодэкам (RS02 або RS03)\n"

#: src/dvdisaster.c:982
msgid ""
"  -j, --jump n               - jump n sectors forward after a read error "
"(default: 16)\n"
msgstr ""
"  -j, --jump n               - прапускаць n сектараў пасля памылкі чытання "
"(па змаўчанні: 16)\n"

#: src/dvdisaster.c:983
msgid ""
"  -m, --method x             - list/select error correction methods "
"(default: RS01)\n"
msgstr ""
"  -m, --method x             - спіс/выбар метадаў карэкцыі памылак (па "
"змаўчанні: RS01)\n"

#: src/dvdisaster.c:984
#, c-format
msgid ""
"  -n, --redundancy x         - error correction data redundancy\n"
"                               e.g. 20%%, 32r (roots), 200m (MiB), normal, high\n"
"                               for RS02/RS03 augmented images, also accepts a medium size:\n"
"                               CD, DVD, DVD9, BD, BD2, BDXL3, BDXL4,\n"
"                               BDNODM, BD2NODM, BDXL3NODM, BDXL4NODM,\n"
"                               or a raw sector count\n"
msgstr ""
"  -n, --redundancy x         - залішнасць даных карэкцыі памылак\n"
"                               напр. 20%%, 32r (карані), 200m (MiB), normal, high\n"
"                               для дапоўненых вобразаў RS02/RS03, таксама прымае памер носьбіта:\n"
"                               CD, DVD, DVD9, BD, BD2, BDXL3, BDXL4,\n"
"                               BDNODM, BD2NODM, BDXL3NODM, BDXL4NODM,\n"
"                               або лічбу сектараў\n"

#: src/dvdisaster.c:990
msgid ""
"  -v, --verbose              - more logs, set env VERBOSE=1 for pre-options "
"parsing logs\n"
msgstr ""
"  -v, --verbose              - больш журналяў; задайце VERBOSE=1 для "
"журналяў да парсінгу параметраў\n"

#: src/dvdisaster.c:991
msgid ""
"  -x, --threads n            - use n threads for en-/decoding (if supported "
"by codec)\n"
msgstr ""
"  -x, --threads n            - выкарыстоўваць n патокаў для "
"кадавання/дэкадавання (калі кодэк падтрымлівае)\n"

#: src/dvdisaster.c:992
msgid ""
"  --adaptive-read            - use optimized strategy for reading damaged "
"media\n"
msgstr ""
"  --adaptive-read            - выкарыстоўваць аптымізаваную стратэгію "
"чытання пашкоджаных носьбітаў\n"

#: src/dvdisaster.c:993
msgid ""
"  --auto-suffix              - automatically add .iso and .ecc file "
"suffixes\n"
msgstr ""
"  --auto-suffix              - аўтаматычна дадаваць суфіксы файлаў .iso і "
".ecc\n"

#: src/dvdisaster.c:994
msgid ""
"  --cache-size n             - image cache size in MiB during -c mode "
"(default: 32MiB)\n"
msgstr ""
"  --cache-size n             - памер кэша вобраза ў MiB у рэжыме -c (па "
"змаўчанні: 32MiB)\n"

#: src/dvdisaster.c:995
msgid "  --dao                      - assume DAO disc; do not trim image end\n"
msgstr ""
"  --dao                      - лічыць дыск DAO; не абразаць канец вобраза\n"

#: src/dvdisaster.c:996
msgid ""
"  --defective-dump d         - directory for saving incomplete raw sectors\n"
msgstr ""
"  --defective-dump d         - дырэкторыя для захавання няпоўных сырых "
"сектараў\n"

#: src/dvdisaster.c:998
msgid ""
"  --driver=sg/cdrom          - use sg(default) or alternative cdrom driver "
"(see man page!)\n"
msgstr ""
"  --driver=sg/cdrom          - выкарыстоўваць sg(па змаўчанні) або "
"альтэрнатыўны драйвер cdrom (гл. man!)\n"

#: src/dvdisaster.c:1000
msgid ""
"  --bruteforce-rs03-search   - enable bruteforce linear scan for RS03 data "
"(slow!)\n"
msgstr ""
"  --bruteforce-rs03-search   - уключыць пасеквенцыйны перабор для пошуку "
"даных RS03 (павольна!)\n"

#: src/dvdisaster.c:1001
msgid "  --eject                    - eject medium after successful read\n"
msgstr ""
"  --eject                    - выштурхнуць носьбіт пасля паспяховага "
"чытання\n"

#: src/dvdisaster.c:1002
msgid ""
"  --encoding-algorithm x     - possible values: 32bit, 64bit, SSE2, "
"AltiVec\n"
msgstr ""
"  --encoding-algorithm x     - магчымыя значэнні: 32bit, 64bit, SSE2, "
"AltiVec\n"

#: src/dvdisaster.c:1003
msgid "  --encoding-io-strategy x   - possible values: readwrite, mmap\n"
msgstr "  --encoding-io-strategy x   - магчымыя значэнні: readwrite, mmap\n"

#: src/dvdisaster.c:1004
msgid "  --fill-unreadable n        - fill unreadable sectors with byte n\n"
msgstr "  --fill-unreadable n        - запаўняць нечытэльныя сектары байтам n\n"

#: src/dvdisaster.c:1005
msgid ""
"  --ignore-fatal-sense       - continue reading after potentially fatal "
"error conditon\n"
msgstr ""
"  --ignore-fatal-sense       - працягваць чытанне пасля патэнцыйна фатальнай"
" памылкі\n"

#: src/dvdisaster.c:1006
msgid ""
"  --ignore-iso-size          - ignore image size from ISO/UDF data "
"(dangerous - see man page!)\n"
msgstr ""
"  --ignore-iso-size          - ігнараваць памер вобраза з даных ISO/UDF "
"(небяспечна - гл. man!)\n"

#: src/dvdisaster.c:1007
msgid ""
"  --internal-rereads n       - drive may attempt n rereads before reporting "
"an error\n"
msgstr ""
"  --internal-rereads n       - прылада можа зрабіць n паўторных чытанняў "
"перад паведамленнем аб памылцы\n"

#: src/dvdisaster.c:1008
msgid "  --medium-info              - print info about medium in drive\n"
msgstr ""
"  --medium-info              - вывесці інфармацыю аб носьбіце ў прыладзе\n"

#: src/dvdisaster.c:1009
msgid ""
"  --no-bdr-defect-management - use bigger RS03 images for BD-R (see man "
"page!)\n"
msgstr ""
"  --no-bdr-defect-management - выкарыстоўваць большыя вобразы RS03 для BD-R "
"(гл. man!)\n"

#: src/dvdisaster.c:1010
msgid "  --no-progress              - do not print progress information\n"
msgstr "  --no-progress              - не выводзіць інфармацыю аб прагрэсе\n"

#: src/dvdisaster.c:1011
msgid ""
"  --old-ds-marker            - mark missing sectors compatible with "
"dvdisaster <= 0.70\n"
msgstr ""
"  --old-ds-marker            - пазначаць адсутныя сектары сумесна з "
"dvdisaster <= 0.70\n"

#: src/dvdisaster.c:1012
msgid ""
"  --prefetch-sectors n       - prefetch n sectors for RS03 encoding (uses "
"~nMiB)\n"
msgstr ""
"  --prefetch-sectors n       - папярэдняя загрузка n сектараў для кадавання "
"RS03 (выкарыстоўвае ~nMiB)\n"

#: src/dvdisaster.c:1013
msgid ""
"  --raw-mode n               - mode for raw reading CD media (20 or 21)\n"
msgstr ""
"  --raw-mode n               - рэжым сырога чытання носьбітаў CD (20 або "
"21)\n"

#: src/dvdisaster.c:1014
msgid ""
"  --read-attempts n-m        - attempts n up to m reads of a defective "
"sector\n"
msgstr ""
"  --read-attempts n-m        - спробы ад n да m чытанняў дэфектнага "
"сектара\n"

#: src/dvdisaster.c:1015
msgid "  --read-medium n            - read the whole medium up to n times\n"
msgstr "  --read-medium n            - чытаць увесь носьбіт да n разоў\n"

#: src/dvdisaster.c:1016
msgid "  --read-raw                 - performs read in raw mode if possible\n"
msgstr ""
"  --read-raw                 - выконвае чытанне ў сыром рэжыме, калі "
"магчыма\n"

#: src/dvdisaster.c:1017
msgid ""
"  --regtest                  - tweaks output for compatibility with "
"regtests\n"
msgstr ""
"  --regtest                  - наладжвае вывад для сумяшчальнасці з "
"рэгрэснымі тэстамі\n"

#: src/dvdisaster.c:1018
msgid "  --resource-file p          - get resource file from given path\n"
msgstr ""
"  --resource-file p          - атрымаць файл рэсурсаў па зададзеным шляху\n"

#: src/dvdisaster.c:1019
msgid ""
"  --speed-warning n          - print warning if speed changes by more than n"
" percent\n"
msgstr ""
"  --speed-warning n          - выводзіць папярэджанне, калі хуткасць "
"змяняецца больш чым на n адсоткаў\n"

#: src/dvdisaster.c:1020
msgid "  --spinup-delay n           - wait n seconds for drive to spin up\n"
msgstr "  --spinup-delay n           - чакаць n секунд для раскруткі прылады\n"

#: src/dvdisaster.c:1021
msgid ""
"  --version                  - print version and some configuration info\n"
msgstr ""
"  --version                  - вывесці версію і некаторую інфармацыю аб "
"канфігурацыі\n"

#: src/dvdisaster.c:1022
msgid ""
"  --debug                    - allow advanced dangerous options (use with "
"--help for a list)\n"
msgstr ""
"  --debug                    - дазволіць пашыраныя небяспечныя параметры (з "
"--help для спісу)\n"

#: src/dvdisaster.c:1026
msgid "Debugging options (purposefully undocumented and possibly harmful)\n"
msgstr "Параметры адладкі (наўмысна недакументаваныя і магчыма небяспечныя)\n"

#: src/dvdisaster.c:1027
msgid ""
"  --permissive-medium-type - allow more media types, even theoretically "
"unsupported ones\n"
msgstr ""
"  --permissive-medium-type - дазволіць больш тыпаў носьбітаў, нават "
"тэарэтычна непадтрымліваемых\n"

#: src/dvdisaster.c:1028
msgid "  --byteset s,i,b          - set byte i in sector s to b\n"
msgstr "  --byteset s,i,b          - усталяваць байт i у сектары s на b\n"

#: src/dvdisaster.c:1029
msgid ""
"  --cdump                  - creates C #include file dumps instead of "
"hexdumps\n"
msgstr ""
"  --cdump                  - стварае дампы ў выглядзе C #include замест "
"hexdumps\n"

#: src/dvdisaster.c:1030
msgid "  --compare-images a,b     - compare sectors in images a and b\n"
msgstr "  --compare-images a,b     - параўнаць сектары ў вобразах a і b\n"

#: src/dvdisaster.c:1031
msgid ""
"  --copy-sector a,n,b,m    - copy sector n from image a to sector m in image"
" b\n"
msgstr ""
"  --copy-sector a,n,b,m    - скапіраваць сектар n з вобраза a у сектар m у "
"вобразе b\n"

#: src/dvdisaster.c:1032
msgid "  --erase sector           - erase the given sector\n"
msgstr "  --erase sector           - сцерці пазначаны сектар\n"

#: src/dvdisaster.c:1033
msgid "  --erase n-m              - erase sectors n - m, inclusively\n"
msgstr "  --erase n-m              - сцерці сектары n - m уключна\n"

#: src/dvdisaster.c:1034
msgid "  --examine-rs02           - force RS02 exhaustive search\n"
msgstr "  --examine-rs02           - прымусовы поўны пошук RS02\n"

#: src/dvdisaster.c:1035
msgid "  --examine-rs03           - force RS03 exhaustive search\n"
msgstr "  --examine-rs03           - прымусовы поўны пошук RS03\n"

#: src/dvdisaster.c:1036
msgid ""
"  --fixed-speed-values     - output fixed speed values for better output "
"diffing\n"
msgstr ""
"  --fixed-speed-values     - выводзіць фіксаваныя значэнні хуткасці для "
"лепшага параўнання\n"

#: src/dvdisaster.c:1037
msgid ""
"  --ignore-rs03-header     - ignore RS03 header when repairing (forcing a "
"full search)\n"
msgstr ""
"  --ignore-rs03-header     - ігнараваць загаловак RS03 пры аднаўленні "
"(прымусовы поўны пошук)\n"

#: src/dvdisaster.c:1038
msgid "  --marked-image n         - create image with n marked random sectors\n"
msgstr ""
"  --marked-image n         - стварыць вобраз з n пазначанымі выпадковымі "
"сектарамі\n"

#: src/dvdisaster.c:1039
msgid ""
"  --merge-images a,b       - merge image a with b (a receives sectors from "
"b)\n"
msgstr ""
"  --merge-images a,b       - аб'яднаць вобраз a з b (a атрымлівае сектары з "
"b)\n"

#: src/dvdisaster.c:1040
msgid ""
"  --random-errors e        - seed image with (correctable) random errors\n"
msgstr ""
"  --random-errors e        - запоўніць вобраз (выпраўляльнымі) выпадковымі "
"памылкамі\n"

#: src/dvdisaster.c:1041
msgid ""
"  --random-image n         - create image with n sectors of random numbers\n"
msgstr ""
"  --random-image n         - стварыць вобраз з n сектарамі выпадковых "
"лічбаў\n"

#: src/dvdisaster.c:1042
msgid ""
"  --random-seed n          - random seed for built-in random number "
"generator\n"
msgstr ""
"  --random-seed n          - зерне выпадковасці для ўбудаванага генератара "
"выпадковых лічбаў\n"

#: src/dvdisaster.c:1043
msgid ""
"  --raw-sector n           - shows hexdump of the given raw sector from "
"medium in drive\n"
msgstr ""
"  --raw-sector n           - паказвае hexdump пазначанага сырога сектара з "
"носьбіта ў прыладзе\n"

#: src/dvdisaster.c:1044
msgid ""
"  --read-sector n          - shows hexdump of the given sector from medium "
"in drive\n"
msgstr ""
"  --read-sector n          - паказвае hexdump пазначанага сектара з носьбіта"
" ў прыладзе\n"

#: src/dvdisaster.c:1045
msgid "  --screen-shot            - useful for generating screen shots\n"
msgstr "  --screen-shot            - карысна для стварэння скрыншотаў\n"

#: src/dvdisaster.c:1046
msgid ""
"  --send-cdb arg           - executes given cdb at drive; kills system if "
"used wrong\n"
msgstr ""
"  --send-cdb arg           - выконвае зададзены cdb на прыладзе; знішчае "
"сістэму пры няправільным выкарыстанні\n"

#: src/dvdisaster.c:1047
msgid ""
"  --set-version            - set program version for debugging purposes "
"(dangerous!)\n"
msgstr ""
"  --set-version            - усталяваць версію праграмы для мэт адладкі "
"(небяспечна!)\n"

#: src/dvdisaster.c:1048
msgid ""
"  --show-header n          - assumes given sector is a ecc header and prints"
" it\n"
msgstr ""
"  --show-header n          - лічыць пазначаны сектар загалоўкам ECC і "
"выводзіць яго\n"

#: src/dvdisaster.c:1049
msgid ""
"  --show-sector n          - shows hexdump of the given sector in an image "
"file\n"
msgstr ""
"  --show-sector n          - паказвае hexdump пазначанага сектара ў файле "
"вобраза\n"

#: src/dvdisaster.c:1050
msgid ""
"  --sim-cd image           - simulate a SCSI-Level CD with contents supplied"
" by the ISO image\n"
msgstr ""
"  --sim-cd image           - сімуляваць SCSI-ўзровень CD з змесцівам, "
"пазначаным ISO вобразам\n"

#: src/dvdisaster.c:1051
#, c-format
msgid "  --sim-defects n          - simulate n%% defective sectors on medium\n"
msgstr ""
"  --sim-defects n          - сімуляваць n%% дэфектных сектараў на носьбіце\n"

#: src/dvdisaster.c:1052
msgid "  --truncate n             - truncates image to n sectors\n"
msgstr "  --truncate n             - скарачае вобраз да n сектараў\n"

#: src/dvdisaster.c:1053
msgid ""
"  --zero-unreadable        - replace the \"unreadable sector\" markers with zeros\n"
"\n"
msgstr ""
"  --zero-unreadable        - замяніць маркеры \"нечытэльны сектар\" нулямі\n"
"\n"

#: src/dvdisaster.c:1083
msgid "Optical drive 52X FW 1.02"
msgstr "Аптычная прылада 52X FW 1.02"

#: src/dvdisaster.c:1088
msgid ""
"Using GUI mode: most command-line options are ignored. Look at the "
"preferences in the GUI instead.\n"
msgstr ""
"Выкарыстоўваецца рэжым GUI: большасць параметраў каманднага радка "
