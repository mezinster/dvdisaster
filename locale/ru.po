#~ "  dvdisaster -f,--fix    # Попытаться исправить образ с помощью .ecc-данных.\n"
#~ "  dvdisaster -s,--scan   # Проверить носитель на ошибки чтения.\n"
#~ "  dvdisaster -t,--test   # Проверить целостность файлов .iso и .ecc.\n"
