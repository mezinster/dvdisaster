msgstr "Hata düzeltme dosyası (RS01)"

#: src/ecc-rs01.c:44
msgid "Classic Reed-Solomon method based on polynomial arithmetic"
msgstr "Polinom aritmetiğine dayalı klasik Reed-Solomon yöntemi"

