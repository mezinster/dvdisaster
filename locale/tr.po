msgid "Augmented image (RS02)"
msgstr "Artırılmış görüntü (RS02)"

#: src/ecc-rs02.c:45
msgid "Reed-Solomon method with improved tolerance for defective ecc data"
msgstr "Kusurlu ecc verileri için geliştirilmiş toleranslı Reed-Solomon yöntemi"

#: src/ecc-rs03.c:44
msgid "Multithreaded RS codec (RS03)"
msgstr "Çok iş parçacıklı RS codec (RS03)"

#: src/ecc-rs03.c:45
msgid "Multithreaded Reed-Solomon codec for error correction files and augmented images"
msgstr "Hata düzeltme dosyaları ve artırılmış görüntüler için çok iş parçacıklı Reed-Solomon codec"

