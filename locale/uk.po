msgid "Error correction file (RS01)"
msgstr "Файл виправлення помилок (RS01)"

#: src/ecc-rs01.c:44
msgid "Classic Reed-Solomon method based on polynomial arithmetic"
msgstr "Класичний метод Ріда-Соломона на основі поліноміальної арифметики"

#: src/ecc-rs02.c:44
msgid "Augmented image (RS02)"
msgstr "Розширений образ (RS02)"

#: src/ecc-rs02.c:45
msgid "Reed-Solomon method with improved tolerance for defective ecc data"
msgstr "Метод Ріда-Соломона з підвищеною стійкістю до дефектних даних ecc"

#: src/ecc-rs03.c:44
msgid "Multithreaded RS codec (RS03)"
msgstr "Багатопоточний кодек RS (RS03)"

#: src/ecc-rs03.c:45
msgid "Multithreaded Reed-Solomon codec for error correction files and augmented images"
msgstr "Багатопоточний кодек Ріда-Соломона для файлів виправлення помилок та розширених образів"

