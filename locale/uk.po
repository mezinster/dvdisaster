msgid "Raw sector file prefix: "
msgstr "Raw sector file prefix: "

#: src/preferences.c:2284
msgid ""
"<b>Raw sector file prefix</b>\n"
"\n"
"Use a different prefix for each disc you are trying to recover, e.g. \"disc1-\" and so on."
msgstr "<b>Raw sector file prefix</b>\n\nUse a different prefix for each disc you are trying to recover, e.g. \"disc1-\" and so on."

