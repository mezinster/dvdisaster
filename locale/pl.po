msgstr "Kolorowanie sektora"

#: src/preferences.c:2566 src/rs01-verify.c:129 src/rs02-verify.c:122
#: src/rs03-verify.c:132
msgid "Good sectors"
msgstr "Dobre sektory"

#: src/preferences.c:2566
msgid "Good sector"
msgstr "Dobry sektor"

#: src/preferences.c:2591
msgid ""
"<b>Good sectors</b>\n"
"\n"
"This color indicates good sectors."
msgstr "<b>Dobre sektory</b>\n\nTen kolor wskazuje dobre sektory."

#: src/preferences.c:2596
msgid "Checksum errors"
msgstr "Błędy sumy kontrolnej"

#: src/preferences.c:2596
msgid "Checksum error"
msgstr "Błąd sumy kontrolnej"

#: src/preferences.c:2621
msgid ""
"<b>Checksum errors</b>\n"
"\n"
"This color is used for displaying sectors with wrong check sums."
msgstr "<b>Błędy sumy kontrolnej</b>\n\nTen kolor jest używany do wyświetlania sektorów z"

#: src/preferences.c:2626
msgid "Unreadable sectors"
msgstr "Niedostępne sektory"

#: src/preferences.c:2626
msgid "Unreadable"
msgstr "Niedostępny"

#: src/preferences.c:2651
msgid ""
"<b>Unreadable sectors</b>\n"
"\n"
"This color is used for marking unreadable sectors."
msgstr "<b>Niedostępne sektory</b>\n\nTen kolor jest używany do oznaczania niedostępnych"

#: src/preferences.c:2656
msgid "Present sectors"
msgstr "Obecne sektory"

#: src/preferences.c:2656
msgid "Present sector"
msgstr "Obecny sektor"

#: src/preferences.c:2681
msgid ""
"<b>Present sectors</b>\n"
"\n"
"Sectors which are already present are marked with this color."
msgstr "<b>Obecne sektory</b>\n\nSektory, które już są obecne, są oznaczane"

#: src/preferences.c:2686
msgid "Ignored sectors"
msgstr "Ignorowane sektory"

#: src/preferences.c:2686
msgid "Ignored sector"
msgstr "Ignorowany sektor"

#: src/preferences.c:2711
msgid ""
"<b>Ignored sectors</b>\n"
"\n"
"Sectors marked with this color will not be processed in the current run."
msgstr "<b>Ignorowane sektory</b>\n\nSektory oznaczone tym kolorem nie będą przetwarzane"

#: src/preferences.c:2717
msgid "Highlit sectors"
msgstr "Podświetlone sektory"

#: src/preferences.c:2717
msgid "Highlit sector"
msgstr "Podświetlony sektor"

#: src/preferences.c:2742
msgid ""
"<b>Highlit sectors</b>\n"
"\n"
"This color is used for temporarily highlighting sectors during adaptive reading."
msgstr "<b>Podświetlone sektory</b>\n\nTen kolor jest używany do tymczasowego wyróżniania"

#: src/preferences.c:2748
msgid "Text colors"
msgstr "Kolory tekstu"

#: src/preferences.c:2758
msgid "Positive text"
msgstr "Tekst pozytywny"

#: src/preferences.c:2783
msgid ""
"<b>Positive text</b>\n"
"\n"
"Good news are printed in this color."
msgstr "<b>Tekst pozytywny</b>\n\nDobre wiadomości są drukowane w tym kolorze."

#: src/preferences.c:2788
msgid "Negative text"
msgstr "Tekst negatywny"

#: src/preferences.c:2813
msgid ""
"<b>Negative text</b>\n"
"\n"
"Bad news are printed in this color."
msgstr "<b>Tekst negatywny</b>\n\nZłe wiadomości są drukowane w tym kolorze."

#: src/preferences.c:2818
msgid "Curve colors"
msgstr "Kolory krzywej"

#: src/preferences.c:2827
msgid "Curve color"
msgstr "Kolor krzywej"

#: src/preferences.c:2852
msgid ""
"<b>Curve color and labels</b>\n"
"\n"
"The reading speed curve, its left side and top labels are printed in this color."
msgstr "<b>Kolor krzywej i etykiety</b>\n\nKrzywej prędkości czytania, jej lewa strona"

#: src/preferences.c:2858 src/read-linear-window.c:405
msgid "C2 errors"
msgstr "Błędy C2"

#: src/preferences.c:2883
msgid ""
"<b>C2 error color</b>\n"
"\n"
"The logarithmic bar graph showing the C2 errors is rendered in this color during the \"read\" and \"scan\" operations."
msgstr "<b>Kolor błędu C2</b>\n\nWykres słupkowy logarytmiczny pokazujący błędy C2"

#: src/preferences.c:2890
msgid "Error correction load"
msgstr "Obciążenie korekcji błędów"

#: src/preferences.c:2915
msgid ""
"<b>Error correction load</b>\n"
"\n"
"The bar graph showing the error correction load is rendered in this color during the \"Fix\" operation."
msgstr "<b>Obciążenie korekcji błędów</b>\n\nWykres słupkowy pokazujący obciążenie korekcji błędów"

#: src/preferences.c:2921
msgid "Default color scheme"
msgstr "Domyślny schemat kolorów"

#: src/preferences.c:2928
msgid "Misc"
msgstr "Różne"

#: src/preferences.c:2932
msgid "Logging"
msgstr "Rejestrowanie"

#: src/preferences.c:2939 src/preferences.c:2940
msgid "Verbose logging"
msgstr "Szczegółowe rejestrowanie"

#: src/preferences.c:2965
msgid ""
"<b>Verbose logging</b>\n"
"\n"
"More information will be supplied in the Log window and/or log file. Useful for debugging, but may lead to slower performance."
msgstr "<b>Szczegółowe rejestrowanie</b>\n\nWięcej informacji będzie dostarczane w oknie dziennika"

#: src/preferences.c:2972
msgid "Logfile:"
msgstr "Plik dziennika:"

#: src/preferences.c:2973
msgid "Copy log to file:"
msgstr "Skopiuj dziennik do pliku:"

#: src/preferences.c:2982
msgid "Delete"
msgstr "Usuń"

#: src/preferences.c:3028
msgid ""
"<b>Logfile</b>\n"
